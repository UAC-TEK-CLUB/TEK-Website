// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================================
// 1. IDENTITY & ACCESS  (ISA: Member -> Officer | Regular)
// ==========================================================

enum MembershipStatus {
  ACTIVE
  INACTIVE
  ALUMNI
  SUSPENDED
}

enum MemberType {
  OFFICER
  REGULAR
}

model Member {
  memberId         String           @id @default(cuid()) @map("member_id")
  /** Site login id (chosen at registration). Stored lowercase. */
  username         String           @unique @map("username")
  /** Official university / campus ID from the application (not used for login). */
  universityId     String           @unique @map("university_id")
  email            String           @unique
  firstName        String           @map("first_name")
  lastName         String           @map("last_name")
  passwordHash     String?          @map("password_hash")
  joinDate         DateTime         @default(now()) @map("join_date")
  membershipStatus MembershipStatus @default(ACTIVE) @map("membership_status")
  memberType       MemberType       @map("member_type")

  // ISA 1:1 subtypes
  officerProfile ClubOfficer?
  regularProfile RegularMember?

  // Reverse relations
  labApplications  LabApplication[]
  labProposals     LabProposal[]      @relation("ProposedBy")
  attendance       AttendanceRecord[]
  bulletinPosts    BulletinPost[]
  galleryUploads   GalleryPhoto[]
  sentMessages     ChatMessage[]      @relation("Sender")
  receivedMessages ChatMessage[]      @relation("Receiver")
  tutoringVideos   TutoringVideo[]
  passwordChangeTickets PasswordChangeTicket[]
  /** Labs this member leads (lab leader dashboard). */
  ledLabs          Lab[]              @relation("LabLeader")

  @@map("members")
}

enum RecoveryPurpose {
  REVEAL_USERNAME
  PASSWORD_RESET
}

model AccountRecoveryCode {
  accountRecoveryCodeId String          @id @default(cuid()) @map("account_recovery_code_id")
  purpose                 RecoveryPurpose @map("purpose")
  /** SHA-256 of server secret + ":" + six-digit code (never store plaintext OTP). */
  codeHash                String          @map("code_hash")
  universityId            String          @map("university_id")
  /** Lowercase site username when purpose is PASSWORD_RESET. */
  usernameNorm            String?         @map("username_norm")
  expiresAt               DateTime        @map("expires_at")
  usedAt                  DateTime?       @map("used_at")
  attemptCount            Int             @default(0) @map("attempt_count")
  createdAt               DateTime        @default(now()) @map("created_at")

  @@index([universityId, purpose])
  @@map("account_recovery_codes")
}

model PasswordChangeTicket {
  passwordChangeTicketId String    @id @default(cuid()) @map("password_change_ticket_id")
  memberId               String    @map("member_id")
  token                  String    @unique @map("token")
  expiresAt              DateTime  @map("expires_at")
  usedAt                 DateTime? @map("used_at")

  member Member @relation(fields: [memberId], references: [memberId], onDelete: Cascade)

  @@index([memberId])
  @@map("password_change_tickets")
}

enum OfficerRole {
  PRESIDENT
  SUPERVISOR
  LEADER
}

model ClubOfficer {
  memberId         String      @id @map("member_id")
  /** Legacy numeric rank; permissions use officerRole only (president & supervisor = full admin). */
  adminAccessLevel Int         @default(1) @map("admin_access_level")
  officerRole      OfficerRole @default(LEADER) @map("officer_role")

  member            Member             @relation(fields: [memberId], references: [memberId], onDelete: Cascade)
  proposalDecisions LabProposal[]      @relation("ReviewedBy")
  healthLogs        WebsiteHealthLog[]

  @@map("club_officers")
}

model RegularMember {
  memberId           String   @id @map("member_id")
  expectedGraduation DateTime @map("expected_graduation")

  member Member @relation(fields: [memberId], references: [memberId], onDelete: Cascade)

  @@map("regular_members")
}

// ==========================================================
// 2. RECRUITMENT PIPELINE
// ==========================================================

model Visitor {
  visitorId   String   @id @default(cuid()) @map("visitor_id")
  ipAddress   String   @map("ip_address")
  browserType String   @map("browser_type")
  visitedAt   DateTime @default(now()) @map("visited_at")

  applications ClubApplication[]

  @@map("visitors")
}

model Applicant {
  universityId String @id @map("university_id")
  firstName    String @map("first_name")
  lastName     String @map("last_name")
  email        String @unique

  applications ClubApplication[]

  @@map("applicants")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model ClubApplication {
  clubAppId           String            @id @default(cuid()) @map("club_app_id")
  applicantId         String            @map("applicant_id")
  visitorId           String?           @map("visitor_id")
  major               String
  codingExperience    String            @map("coding_experience")
  status              ApplicationStatus @default(PENDING)
  submittedAt         DateTime          @default(now()) @map("submitted_at")
  accountSetupToken   String?           @unique @map("account_setup_token")

  applicant Applicant @relation(fields: [applicantId], references: [universityId], onDelete: Cascade)
  visitor   Visitor?  @relation(fields: [visitorId], references: [visitorId], onDelete: SetNull)

  @@index([status])
  @@map("club_applications")
}

// ==========================================================
// 3. LAB & OPERATIONS
// ==========================================================

model Lab {
  labId          String   @id @default(cuid()) @map("lab_id")
  labName        String   @unique @map("lab_name")
  description    String
  objective      String
  createdAt      DateTime @default(now()) @map("created_at")
  leaderMemberId String?  @map("leader_member_id")

  leader       Member?          @relation("LabLeader", fields: [leaderMemberId], references: [memberId], onDelete: SetNull)
  applications LabApplication[]
  announcements BulletinPost[]
  spotlight    LeaderProject?

  @@map("labs")
}

model LabApplication {
  labAppId  String            @id @default(cuid()) @map("lab_app_id")
  memberId  String            @map("member_id")
  labId     String            @map("lab_id")
  status    ApplicationStatus @default(PENDING)
  appliedAt DateTime          @default(now()) @map("applied_at")

  member Member @relation(fields: [memberId], references: [memberId], onDelete: Cascade)
  lab    Lab    @relation(fields: [labId], references: [labId], onDelete: Cascade)

  @@unique([memberId, labId])
  @@map("lab_applications")
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

model LabProposal {
  proposalId   String         @id @default(cuid()) @map("proposal_id")
  proposedById String         @map("proposed_by")
  reviewedById String?        @map("reviewed_by")
  proposedName String         @map("proposed_name")
  description  String
  objective    String
  status       ProposalStatus @default(PENDING)
  proposedAt   DateTime       @default(now()) @map("proposed_at")

  proposedBy Member       @relation("ProposedBy", fields: [proposedById], references: [memberId], onDelete: Cascade)
  reviewedBy ClubOfficer? @relation("ReviewedBy", fields: [reviewedById], references: [memberId], onDelete: SetNull)

  @@map("lab_proposals")
}

// ==========================================================
// 4. EVENTS & ATTENDANCE  (M:N associative entity)
// ==========================================================

enum MeetingType {
  GENERAL
  WORKSHOP
  HACKATHON
  SOCIAL
  SHOWCASE
  OFFICER_ONLY
}

model Meeting {
  meetingId   String      @id @default(cuid()) @map("meeting_id")
  title       String
  scheduledAt DateTime    @map("scheduled_at")
  type        MeetingType
  location    String?
  /** RSVP links, agenda links, or other notes visible to members */
  notes       String?

  attendance AttendanceRecord[]

  @@map("meetings")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
}

model AttendanceRecord {
  meetingId        String           @map("meeting_id")
  memberId         String           @map("member_id")
  attendanceStatus AttendanceStatus @map("attendance_status")
  recordedAt       DateTime         @default(now()) @map("recorded_at")

  meeting Meeting @relation(fields: [meetingId], references: [meetingId], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [memberId], onDelete: Cascade)

  @@id([meetingId, memberId])
  @@map("attendance_records")
}

// ==========================================================
// 5. COMMUNITY & ENGAGEMENT
// ==========================================================

model BulletinPost {
  postId   String   @id @default(cuid()) @map("post_id")
  authorId String   @map("author_id")
  /** Null = club-wide announcement (president / supervisor). Set = lab-only (that lab's leader + executives). */
  labId    String?  @map("lab_id")
  title    String
  content  String
  pinned   Boolean  @default(false)
  postedAt DateTime @default(now()) @map("posted_at")

  author Member @relation(fields: [authorId], references: [memberId], onDelete: Cascade)
  lab    Lab?   @relation(fields: [labId], references: [labId], onDelete: Cascade)

  @@index([postedAt])
  @@index([labId])
  @@map("bulletin_board")
}

model GalleryPhoto {
  photoId    String   @id @default(cuid()) @map("photo_id")
  uploaderId String   @map("uploader_id")
  url        String
  caption    String?
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  uploader Member @relation(fields: [uploaderId], references: [memberId], onDelete: Cascade)

  @@map("gallery_photos")
}

model ChatMessage {
  messageId  String    @id @default(cuid()) @map("message_id")
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  content    String
  sentAt     DateTime  @default(now()) @map("sent_at")
  readAt     DateTime? @map("read_at")

  sender   Member @relation("Sender",   fields: [senderId],   references: [memberId], onDelete: Cascade)
  receiver Member @relation("Receiver", fields: [receiverId], references: [memberId], onDelete: Cascade)

  @@index([senderId, receiverId, sentAt])
  @@map("chat_messages")
}

enum VideoProvider {
  YOUTUBE
  VIMEO
  OTHER
}

model TutoringVideo {
  videoId     String        @id @default(cuid()) @map("video_id")
  title       String
  description String?
  videoUrl    String        @map("video_url")
  provider    VideoProvider @default(OTHER)
  uploaderId  String        @map("uploader_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  uploader Member @relation(fields: [uploaderId], references: [memberId], onDelete: Cascade)

  @@index([createdAt])
  @@map("tutoring_videos")
}

model LeaderProject {
  projectId    String   @id @default(cuid()) @map("project_id")
  labId        String   @unique @map("lab_id")
  title        String
  description  String
  photoUrl     String   @map("photo_url")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  lab Lab @relation(fields: [labId], references: [labId], onDelete: Cascade)

  @@index([updatedAt])
  @@map("leader_projects")
}

// ==========================================================
// 6. ADMINISTRATION
// ==========================================================

model WebsiteHealthLog {
  logId        String   @id @default(cuid()) @map("log_id")
  recordedById String   @map("recorded_by")
  metricName   String   @map("metric_name")
  metricValue  Float    @map("metric_value")
  recordedAt   DateTime @default(now()) @map("recorded_at")

  recordedBy ClubOfficer @relation(fields: [recordedById], references: [memberId], onDelete: Cascade)

  @@index([metricName, recordedAt])
  @@map("website_health_logs")
}

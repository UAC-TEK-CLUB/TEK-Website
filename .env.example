# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tek_club?schema=public"

# Auth.js (NextAuth v5) — generate with `openssl rand -base64 32`
AUTH_SECRET="replace_this_with_32_key_secret"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Email (optional in dev — if SMTP_HOST is unset, emails are logged to the server console).
# Production: set all five. Common providers below.
#   AWS SES SMTP:    host=email-smtp.<region>.amazonaws.com, port=587
#   Gmail App Pass:  host=smtp.gmail.com, port=587, user=<email>, password=<app password>
#
# Resend (recommended transactional): https://resend.com
#   1) Add & verify your domain in Resend (DNS TXT + optional MX per their wizard).
#   2) Create an API key; use it as SMTP_PASSWORD below.
#   3) SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_USER=resend  (literal user "resend")
#   4) EMAIL_FROM must use an address on that verified domain, e.g. "UAC TEK Club <noreply@yourdomain.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="UAC TEK Club <noreply@outlook.com>"
# Used to build absolute URLs in emails. Falls back to NEXTAUTH_URL.
APP_URL="http://localhost:3000"

# Optional: permanent Discord invite (https://discord.gg/…). Shown on /messages with an “Open Discord” button.
DISCORD_INVITE_URL=""

# S3-compatible storage for Phase 5 gallery uploads (Cloudflare R2 / Supabase / AWS)
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
# When all S3_* vars above are set, member image uploads (gallery, lab spotlight, lab announcement
# images) go to the bucket. In development without S3, files are saved under public/uploads/ (see .gitignore).

# --- Cloudflare Workers (production) ---
# Set these on the Worker (wrangler secret / dashboard). See docs/deploy-cloudflare.md
# NEXTAUTH_URL / AUTH_URL = https://your-domain
# AUTH_TRUST_HOST=true
# DATABASE_URL = use your host's pooling / serverless string (e.g. Neon)

# Bootstrap president officer — `npx prisma db seed` (sign in at /login with username + password).
# Set to "false" once real officers exist so seed does not recreate the demo president.
SEED_BOOTSTRAP_OFFICER="true"
# university_id = official campus ID on the member record (rosters); not used for login.
SEED_OFFICER_USERNAME="tek0001"
SEED_OFFICER_UNIVERSITY_ID="TEK0001"
SEED_OFFICER_EMAIL="admin@tek.club"
SEED_OFFICER_PASSWORD="ChangeMeNow!"
# Faculty supervisor (optional) — same seed command. Set SEED_BOOTSTRAP_SUPERVISOR="true" to create
# / update them using the vars below (defaults: campus ID TEK_SUPERVISOR, placeholder seed email).
# Or omit the flag and set SEED_SUPERVISOR_UNIVERSITY_ID and/or SEED_SUPERVISOR_EMAIL instead.
# SEED_BOOTSTRAP_SUPERVISOR="true"
# SEED_SUPERVISOR_UNIVERSITY_ID="U1234567"
# SEED_SUPERVISOR_USERNAME="prof_smith"
# SEED_SUPERVISOR_EMAIL="smith@university.edu"
# SEED_SUPERVISOR_PASSWORD="ChangeMeNow!"
# SEED_SUPERVISOR_FIRST_NAME="Jane"
# SEED_SUPERVISOR_LAST_NAME="Doe"
